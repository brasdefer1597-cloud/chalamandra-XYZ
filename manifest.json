{
  "manifest_version": 3,
  "name": "XYZ 369 Dialectic Decoder",
  "version": "1.0.0",
  "description": "Transform web content into dialectic synthesis (Thesis-Antithesis-Synthesis) using Hybrid AI (Gemini Nano + Cloud).",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "frontend/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png"
    }
  },
  "options_page": "frontend/options/options.html",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "backend/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["frontend/content.js"]
    }
  ]
}
